	$(MAKE) -f bin/.build/ARMv7A/libXKCP.dylib.make ARMv7A/libXKCP.dylib.pack
ARMv7A/libXKCP.dylib.vcxproj: bin/VC/ARMv7A_libXKCP.dylib.vcxproj
bin/VC/ARMv7A_libXKCP.dylib.vcxproj: bin/.build/ARMv7A/libXKCP.dylib.target bin/.build/ARMv7A/libXKCP.dylib/config.h
	mkdir -p bin/VC/ARMv7A/libXKCP.dylib//config
	cp bin/.build/ARMv7A/libXKCP.dylib/config.h bin/VC/ARMv7A/libXKCP.dylib//config
	xsltproc -o $@ support/XKCBuild/src/ToVCXProj.xsl bin/.build/ARMv7A/libXKCP.dylib.target
bin/.build/ARMv7A/libXKCP.dylib.make: bin/.build/ARMv7A/libXKCP.dylib.target support/XKCBuild/src/ToTargetMakefile.xsl
	mkdir -p $(dir $@)
	xsltproc -o $@ support/XKCBuild/src/ToTargetMakefile.xsl $<
bin/.build/ARMv7A/libXKCP.dylib/config.h: bin/.build/ARMv7A/libXKCP.dylib.target support/XKCBuild/src/ToTargetConfigFile.xsl
	mkdir -p $(dir $@)
	xsltproc -o $@ support/XKCBuild/src/ToTargetConfigFile.xsl $<
bin/.build/ARMv7A/libXKCP.dylib.target: support/XKCBuild/src/ToOneTarget.xsl bin/.build/Makefile.expanded Makefile.build
	mkdir -p $(dir $@)
	xsltproc -o $@ -param nameTarget "'ARMv7A/libXKCP.dylib'" support/XKCBuild/src/ToOneTarget.xsl bin/.build/Makefile.expanded

