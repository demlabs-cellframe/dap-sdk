AVR8/libXKCP.so.pack: bin/.build/AVR8/libXKCP.so.make bin/.build/AVR8/libXKCP.so/config.h
	$(MAKE) -f bin/.build/AVR8/libXKCP.so.make AVR8/libXKCP.so.pack
AVR8/libXKCP.so.vcxproj: bin/VC/AVR8_libXKCP.so.vcxproj
bin/VC/AVR8_libXKCP.so.vcxproj: bin/.build/AVR8/libXKCP.so.target bin/.build/AVR8/libXKCP.so/config.h
	mkdir -p bin/VC/AVR8/libXKCP.so//config
	cp bin/.build/AVR8/libXKCP.so/config.h bin/VC/AVR8/libXKCP.so//config
	xsltproc -o $@ support/XKCBuild/src/ToVCXProj.xsl bin/.build/AVR8/libXKCP.so.target
bin/.build/AVR8/libXKCP.so.make: bin/.build/AVR8/libXKCP.so.target support/XKCBuild/src/ToTargetMakefile.xsl
	mkdir -p $(dir $@)
	xsltproc -o $@ support/XKCBuild/src/ToTargetMakefile.xsl $<
bin/.build/AVR8/libXKCP.so/config.h: bin/.build/AVR8/libXKCP.so.target support/XKCBuild/src/ToTargetConfigFile.xsl
	mkdir -p $(dir $@)
	xsltproc -o $@ support/XKCBuild/src/ToTargetConfigFile.xsl $<
bin/.build/AVR8/libXKCP.so.target: support/XKCBuild/src/ToOneTarget.xsl bin/.build/Makefile.expanded Makefile.build
	mkdir -p $(dir $@)
	xsltproc -o $@ -param nameTarget "'AVR8/libXKCP.so'" support/XKCBuild/src/ToOneTarget.xsl bin/.build/Makefile.expanded

