.PHONY: ARMv7M/UnitTests bin/ARMv7M/UnitTests ARMv7M/UnitTests.pack ARMv7M/UnitTests.vcxproj
ARMv7M/UnitTests: bin/.build/ARMv7M/UnitTests/config.h bin/ARMv7M/UnitTests
bin/ARMv7M/UnitTests: bin/.build/ARMv7M/UnitTests.make
	$(MAKE) -f bin/.build/ARMv7M/UnitTests.make ARMv7M/UnitTests
ARMv7M/UnitTests.pack: bin/.build/ARMv7M/UnitTests.make bin/.build/ARMv7M/UnitTests/config.h
	$(MAKE) -f bin/.build/ARMv7M/UnitTests.make ARMv7M/UnitTests.pack
ARMv7M/UnitTests.vcxproj: bin/VC/ARMv7M_UnitTests.vcxproj
bin/VC/ARMv7M_UnitTests.vcxproj: bin/.build/ARMv7M/UnitTests.target bin/.build/ARMv7M/UnitTests/config.h
	mkdir -p bin/VC/ARMv7M/UnitTests//config
	cp bin/.build/ARMv7M/UnitTests/config.h bin/VC/ARMv7M/UnitTests//config
	xsltproc -o $@ support/XKCBuild/src/ToVCXProj.xsl bin/.build/ARMv7M/UnitTests.target
bin/.build/ARMv7M/UnitTests.make: bin/.build/ARMv7M/UnitTests.target support/XKCBuild/src/ToTargetMakefile.xsl
	mkdir -p $(dir $@)
	xsltproc -o $@ support/XKCBuild/src/ToTargetMakefile.xsl $<
bin/.build/ARMv7M/UnitTests/config.h: bin/.build/ARMv7M/UnitTests.target support/XKCBuild/src/ToTargetConfigFile.xsl
	mkdir -p $(dir $@)
	xsltproc -o $@ support/XKCBuild/src/ToTargetConfigFile.xsl $<
bin/.build/ARMv7M/UnitTests.target: support/XKCBuild/src/ToOneTarget.xsl bin/.build/Makefile.expanded Makefile.build
	mkdir -p $(dir $@)
	xsltproc -o $@ -param nameTarget "'ARMv7M/UnitTests'" support/XKCBuild/src/ToOneTarget.xsl bin/.build/Makefile.expanded

