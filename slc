#!/bin/bash
# Smart Layered Context - CLI v2.0
# Обёртка для запуска модульного CLI

# Определяем путь к скрипту

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_SCRIPT="$SCRIPT_DIR/.context/tools/scripts/slc_cli.py"



# Проверяем существование скрипта
if [ ! -f "$CLI_SCRIPT" ]; then
    echo "❌ CLI скрипт не найден: $CLI_SCRIPT"
    echo "💡 Убедитесь, что вы находитесь в корне проекта СЛК"
    exit 1
fi

# Проверяем наличие Python 3
if ! command -v python3 &> /dev/null; then
    echo "❌ Python 3 не найден"
    echo "💡 Установите Python 3 для работы СЛК CLI"
    exit 1
fi

# Запускаем модульный CLI с переданными аргументами
exec python3 "$CLI_SCRIPT" "$@" 