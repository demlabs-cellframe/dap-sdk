        "dap_string_simd_find(haystack, needle)",
        "dap_string_simd_compare(a, b)",
        "dap_string_simd_validate_utf8(str)"
      ]
    },

    "dap_object_pool": {
      "location": "module/core/include/dap_object_pool.h",
      "purpose": "Object pool для всего SDK",
      "api": [
        "dap_object_pool_create(object_size)",
        "dap_object_pool_alloc(pool)",
        "dap_object_pool_free(pool, obj)"
      ]
    },

    "module_jit": {
      "location": "module/jit/",
      "purpose": "JIT compilation engine для JSONPath и других DSL",
