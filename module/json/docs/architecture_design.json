        "dap_json_object_t": {
          "description": "JSON object (key-value map)",
          "implementation": "Hash table (open addressing, Robin Hood hashing)",
          "load_factor": "0.75",
          "growth": "2x on overflow"
        },
        "dap_json_array_t": {
          "description": "JSON array (dynamic array)",
          "implementation": "Dynamic array (exponential growth)",
          "growth": "1.5x on overflow",
          "optimization": "Small array optimization (<= 8 elements inline)"
        }
      },
      "functions": {
        "parsing": [
          "dap_json_parse(const char *json, size_t len) → dap_json_value_t*",
          "dap_json_parse_file(const char *path) → dap_json_value_t*",
          "dap_json_parse_with_options(const char *json, dap_json_options_t opts) → dap_json_value_t*"
        ],
        "access": [
          "dap_json_object_get(object, key) → value",
          "dap_json_array_get(array, index) → value",
