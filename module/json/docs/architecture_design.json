    "architecture_principles": {
      "correctness_first": "правильно важнее чем быстро - TDD подход",
      "zero_dependencies": "Pure C, no external libs except libc",
      "platform_agnostic": "Works on x86/ARM/любая архитектура",
      "abi_stable": "Stable C ABI for long-term compatibility",
