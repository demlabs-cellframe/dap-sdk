  "parallel_stage2_design": {
    "motivation": "simdjson Stage 2 sequential → bottleneck на multi-core",
    "our_innovation": "Parallel Stage 2 с work-stealing",
    
    "work_decomposition": {
      "unit_of_work": "Single JSON object or array",
      "granularity": "Any object/array with >N elements (N=8) → spawn work",
      "base_case": "Small objects (<8 keys) → parse inline"
    },

    "work_stealing_queue": {
      "type": "Deque (double-ended queue) per thread",
      "operations": {
        "push": "Thread pushes work to its own queue (tail)",
        "pop": "Thread pops work from its own queue (tail) - LIFO for cache locality",
        "steal": "Other threads steal from head - FIFO to avoid contention"
      },
      "implementation": "Chase-Lev work-stealing deque (lock-free)",
      "reference": "\"Dynamic Circular Work-Stealing Deque\" (Chase & Lev, 2005)"
    },

    "synchronization": {
      "parent_child": "Parent has atomic counter of pending children",
      "completion": "Child decrements counter when done",
      "waiting": "Parent spins on counter == 0 or steals more work",
      "no_locks": "Only atomic operations (CAS, fetch_add, fetch_sub)"
    },

    "load_balancing": {
      "strategy": "Automatic via work stealing",
      "idle_threads": "Idle thread steals work from busiest queue",
      "efficiency": "Near-linear scalup до 8-16 cores"
    },

    "expected_performance": {
      "speedup_vs_sequential": "1.5-2x (2 cores), 2.5-4x (4 cores), 4-8x (8 cores)",
      "vs_simdjson": "+30-50% благодаря parallel Stage 2"
    },

    "implementation_phases": {
      "phase_1": "Sequential Stage 2 (работает корректно)",
      "phase_2": "Identify parallelizable units (objects/arrays)",
      "phase_3": "Implement work queue + worker threads",
      "phase_4": "Tune granularity + load balancing"
    }
  },

  "security_considerations": {
