        "c_reference": "0.8-1.2 GB/s"
      },
      "latency": {
        "first_event": "<10 μs",
        "small_json_1kb": "<50 μs",
        "medium_json_100kb": "<500 μs"
      },
      "memory": {
        "streaming_mode": "O(depth) = 5-10 KB",
