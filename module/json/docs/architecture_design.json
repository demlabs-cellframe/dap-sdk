  "core_architecture": {
    "overview": "Enhanced simdjson two-stage parsing с parallel Stage 2 и predictive optimizations",
    "pipeline": [
      "Input (JSON string/stream)",
      "→ Stage 1: SIMD Structural Indexing (parallel chunks)",
      "→ Structural Indices (tape/bitset)",
      "→ Stage 2: Parallel DOM Building (work-stealing queue)",
      "→ DOM Tree / SAX Events / Streaming Callback",
      "→ User API (DOM/SAX/Streaming/JSONPath/Schema)"
    ],
    
    "stage_1_structural_indexing": {
      "purpose": "Find all structural characters {[]}:, using SIMD",
      "algorithm": "simdjson-inspired bitwise operations",
      "input": "Raw JSON bytes",
      "output": "Structural indices (tape or bitset)",
      "parallelization": "Process chunks in parallel (chunk size = 64KB)",
      "simd_operations": {
        "character_classification": "SIMD compare для {[]}:,\"\\",
        "quote_detection": "Find all quotes, build quote mask",
        "escape_handling": "clmul-based escape detection (AVX2+)",
        "utf8_validation": "SIMD UTF-8 validation at 13 GB/s",
        "whitespace_skip": "Bitwise OR для пропуска whitespace"
      },
      "data_structures": {
        "structural_tape": {
          "description": "Linear array of (type, position) pairs",
          "type_encoding": "uint8_t: OBJECT_START, ARRAY_START, KEY, VALUE, etc.",
          "position": "uint32_t offset в input buffer",
          "size": "O(structural_chars) = ~5-10% от input size"
        },
        "quote_bitset": {
          "description": "1 bit per byte, 1 = inside quotes",
          "use": "Fast check if character is inside string",
          "size": "input_size / 8 bytes"
        }
      },
      "performance": {
        "expected_throughput": "15-20 GB/s (Stage 1 only, AVX-512)",
        "bottleneck": "Memory bandwidth, не CPU",
        "optimization": "Prefetch next chunk while processing current"
      }
    },

    "stage_2_dom_building": {
      "purpose": "Build DOM tree from structural indices",
      "algorithm": "НАША ИННОВАЦИЯ: Parallel DOM building с work-stealing",
      "input": "Structural tape from Stage 1",
      "output": "dap_json_value_t tree",
      "parallelization": {
        "strategy": "Work-stealing queue for parallel object/array parsing",
        "thread_count": "auto-detect (num_cores)",
        "work_item": "Each object/array is a work item",
        "synchronization": "Lock-free queue (atomic ops)",
        "expected_speedup": "+30-50% vs sequential Stage 2"
      },
      "phases": {
        "phase_1_structural_parse": {
          "description": "Walk structural tape, identify objects/arrays",
          "output": "List of (object_start, object_end) ranges"
        },
        "phase_2_parallel_build": {
          "description": "Each thread takes object/array, builds DOM subtree",
          "coordination": "Parent waits for children via atomic counter"
        },
        "phase_3_link": {
          "description": "Link subtrees into final DOM tree",
          "fast_path": "Pre-allocated arena, no malloc per node"
        }
      },
      "data_structures": {
        "work_queue": {
          "type": "Per-thread work-stealing deque (Chase-Lev: SPMC per queue)",
          "implementation": "Atomic CAS-based, lock-free",
          "work_item": "{ tape_start, tape_end, parent_node, key }",
          "note": "Each thread has own deque (SPMC), collectively forms work-stealing system"
        },
        "dom_node": {
          "type": "dap_json_value_t",
          "size": "32 bytes (cache-friendly)",
          "layout": "type (4 bytes) + value union (24 bytes) + metadata (4 bytes)"
        }
      },
      "memory_management": {
        "arena_allocator": "Bump allocator for DOM nodes",
        "string_pool": "Interned strings for keys (deduplication)",
        "object_pool": "Reusable array storage for small arrays"
      }
    },

    "predictive_parsing": {
      "purpose": "Learn common DAP SDK JSON patterns, enable fast paths",
      "approach": "Runtime profiling + code generation",
      "patterns_to_learn": [
        "Common object schemas (e.g. network packets)",
        "Frequent key names",
        "Typical nesting depths",
        "Value type distributions"
      ],
      "optimizations": {
        "schema_fast_path": "If JSON matches learned schema → skip validation",
        "key_prefetch": "Prefetch likely keys based on history",
        "type_prediction": "Predict value type from key name",
        "layout_optimization": "Reorder fields in DOM for cache locality"
      },
      "expected_gain": "+10-20% для типичных DAP SDK workloads",
      "implementation": "Phase 4.4 (after basic parser + SIMD + parallel Stage 2)",
      "learning_mode": {
        "cold_start": "First 100 parses - collect statistics",
        "hot": "After 100 parses - apply learned optimizations",
        "update": "Continuously update patterns based on new data"
      }
    },

    "hybrid_streaming": {
      "purpose": "yajl-style streaming + simdjson speed",
      "approach": "Chunk-based parallel processing с incremental callbacks",
      "chunking": {
        "chunk_size": "64 KB (L2 cache friendly, L1 typically 32KB)",
        "overlap": "4 KB overlap для boundaries",
        "alignment": "Align на structural characters",
        "rationale": "64KB балансирует между L1 misses и chunk overhead"
      },
      "pipeline": [
        "Read chunk → Stage 1 (parallel) → Stage 2 (parallel) → Callbacks → Next chunk"
      ],
      "memory": "O(chunk_size + depth) = 64KB + 5-10KB",
      "expected_speed": "3-5x faster than yajl",
      "use_cases": [
        "Large JSON files (>100 MB)",
        "Network streams",
        "Log processing"
      ]
    }
  },

  "api_design": {
