  "memory_management": {
    "arena_allocator": {
      "purpose": "Fast allocation для DOM nodes",
      "algorithm": "Bump allocator (pointer increment)",
      "chunk_size": "64 KB (cache-line aligned)",
      "growth": "2x on overflow (faster than 1.5x, acceptable waste)",
      "lifetime": "Tied to dap_json_value_t root",
      "free": "Bulk free (single free() call для всего arena)",
      "performance": "10-100x faster than malloc/free",
      "implementation": {
        "structure": "dap_arena_t { chunks[], current_chunk, offset }",
        "allocation": "if (offset + size <= chunk_size) → bump; else → new chunk",
        "alignment": "16 bytes (SIMD friendly), 64 bytes for large objects"
      },
      "thread_safety": "Per-parser arena (no synchronization needed)"
    },

    "string_pool": {
      "purpose": "Deduplicate object keys",
      "algorithm": "String interning (hash table)",
      "hash_function": "FNV-1a or xxHash",
      "collision_resolution": "Chaining",
      "expected_saving": "30-50% для типичных JSON (много дублей ключей)",
      "implementation": {
        "structure": "dap_string_pool_t { hash_table, arena }",
        "intern": "hash(key) → lookup → if exists: return; else: allocate + insert"
      }
    },

    "object_pool": {
      "purpose": "Reuse array storage для small arrays",
      "algorithm": "Free-list по размерам",
      "size_classes": "[8, 16, 32, 64, 128, 256] elements",
      "fallback": "malloc для больших массивов",
      "performance": "Avoid allocation churn для temporary arrays",
      "implementation": {
        "structure": "dap_object_pool_t { free_lists[NUM_SIZE_CLASSES] }",
        "alloc": "pop from free_list[size_class]",
        "free": "push to free_list[size_class]"
      }
    },

    "reference_counting": {
      "purpose": "Safe memory management для shared values",
      "algorithm": "Atomic refcount (32-bit)",
      "operations": {
        "retain": "atomic_fetch_add(&refcount, 1)",
        "release": "if (atomic_fetch_sub(&refcount, 1) == 1) → free"
      },
      "cycles": "Не поддерживаются (пользователь не должен создавать cycles)",
      "note": "Optional - можно использовать manual free если нет sharing"
    }
  },

