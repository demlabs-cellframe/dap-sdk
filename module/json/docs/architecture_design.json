  "testing_strategy": {
    "unit_tests": {
      "coverage_target": ">90% code coverage",
      "frameworks": "dap_test framework",
      "categories": [
        "API correctness",
        "Edge cases",
        "Error handling",
        "Memory safety"
      ],
      "count": "~200 unit tests"
    },

    "correctness_tests": {
      "approach": "SIMD vs reference implementation",
      "methodology": "For every input, SIMD output === reference output",
      "test_suite": "JSONTestSuite (>300 test cases)",
      "property_based": "QuickCheck-style random inputs"
    },

    "performance_tests": {
      "benchmark_suite": {
        "competitors": ["json-c", "RapidJSON", "simdjson", "yajl"],
        "datasets": [
          "twitter.json (600 KB)",
          "citm_catalog.json (1.7 MB)",
          "canada.json (2.2 MB)",
          "large_file.json (100 MB)"
        ],
        "metrics": ["throughput (GB/s)", "latency (μs)", "memory (MB)"]
      },
      "ablation_studies": {
        "purpose": "Quantify impact of each optimization",
        "tests": [
          "SIMD vs scalar",
          "Parallel Stage 2 vs sequential",
          "Arena vs malloc",
          "String interning vs no interning"
        ]
      }
    },

    "fuzzing": {
      "tool": "AFL++ or libFuzzer",
      "corpus": "JSONTestSuite + generated samples",
      "duration": "24-48 hours continuous",
      "goal": "Find crashes, hangs, memory leaks"
    },

    "continuous_benchmarking": {
      "frequency": "Every commit to main branch",
      "comparison": "vs json-c, RapidJSON, simdjson baselines",
      "regression_alert": "If performance drops >5% → alert"
    }
  },

  "reusable_components": {
    "dap_cpu_detect": {
      "location": "module/core/include/dap_cpu_detect.h",
