  },
  
  "problem_statement": {
    "current_situation": "VPN currently supports only direct single-hop connections to VPN servers",
    "limitations": [
      "No multi-hop routing for enhanced privacy",
      "No route optimization based on performance metrics",
      "No cost/speed trade-off options",
      "No geographic entry/exit point selection",
      "Server selection is manual and not optimized"
    ],
    "business_impact": [
      "Limited privacy protection (single hop)",
      "Suboptimal performance (no intelligent routing)",
      "No premium service tiers (no multi-hop upsell)",
      "Cannot compete with advanced VPN providers (NordVPN, ProtonVPN)",
      "Limited monetization options"
    ],
    "payment_policy": {
      "client": "Payment is ALWAYS required. No free mode support in VPN client.",
      "server": "For backward compatibility, server MAY support legacy free mode, but ONLY for direct (non-multi-hop) connections in old protocol format.",
      "multi_hop": "Multi-hop routing is ONLY available with paid mode. Free legacy mode does not support multi-hop."
    }
  },
  
  "objectives": {
    "primary": "Implement multi-hop VPN with intelligent route selection based on GDB-published statistics",
    "secondary": [
      "Create GDB cluster for VPN nodes to share connection statistics",
      "Implement route optimization algorithm with multiple criteria",
      "Support premium multi-hop routes for enhanced speed",
      "Allow user-defined routing preferences (speed vs security vs cost)",
      "Maintain backward compatibility with single-hop mode"
    ],
    "success_criteria": [
      "Multi-hop routes work reliably (1-5 hops)",
      "Route selection algorithm optimizes for user preferences",
      "GDB statistics are accurate and up-to-date",
      "Premium routes provide measurable speed improvements",
      "Performance overhead < 20% for 2-hop routes"
    ]
  },
  
  "architecture": {
    "gdb_statistics_cluster": {
      "description": "VPN nodes form a GDB cluster to publish and share connection statistics",
      "components": {
        "vpn_node_stats": {
          "description": "Statistics published by each VPN node",
          "data_structure": {
            "node_id": "Unique node identifier (hash)",
            "location": {
              "country_code": "ISO 3166-1 alpha-2 (e.g., 'US', 'DE')",
              "region": "Geographic region (e.g., 'North America', 'Europe')",
              "city": "Optional city name",
              "coordinates": {"lat": "float", "lon": "float"}
            },
            "performance": {
              "bandwidth_up_mbps": "Upload bandwidth in Mbps",
              "bandwidth_down_mbps": "Download bandwidth in Mbps",
              "latency_ms": "Average latency to internet in ms",
              "packet_loss_percent": "Packet loss percentage (0.0-100.0)",
              "uptime_percent": "Uptime percentage over last 24h"
            },
            "capacity": {
              "active_connections": "Current number of active connections",
              "max_connections": "Maximum allowed connections",
              "cpu_usage_percent": "CPU usage (0-100)",
              "memory_usage_percent": "Memory usage (0-100)"
            },
            "pricing": {
              "cost_per_gb": "Cost per GB in datoshi",
              "cost_per_hour": "Cost per hour in datoshi",
              "premium_multiplier": "Premium route multiplier (e.g., 1.5x)"
            },
            "routes": {
              "peer_nodes": ["List of node_ids this node can route to"],
              "peer_latencies": {"node_id": "latency_ms"},
              "peer_bandwidths": {"node_id": "bandwidth_mbps"}
            },
            "timestamp": "Unix timestamp of last update",
            "signature": "Node signature for authenticity"
          }
        },
        "gdb_schema": {
          "table_name": "vpn_nodes_stats",
          "key_format": "vpn:node:<node_id>",
          "update_frequency": "Every 5 minutes",
          "ttl": "30 minutes (stale data removed)",
          "replication": "Full replication across VPN nodes cluster"
        }
      }
    },
    "route_selection_algorithm": {
      "description": "Intelligent algorithm to select optimal multi-hop route",
      "criteria": [
        {
          "name": "brevity",
          "description": "Minimize number of hops (ideally 1-2)",
          "weight": "user_configurable",
          "calculation": "hop_count_penalty = hop_count * brevity_weight"
        },
        {
          "name": "security",
          "description": "Entry node in user's country, exit node abroad",
          "weight": "user_configurable",
          "calculation": "security_score = entry_same_country ? 100 : 0 + exit_different_country ? 100 : 0"
        },
        {
          "name": "speed",
          "description": "Maximize bandwidth and minimize latency",
          "weight": "user_configurable",
          "calculation": "speed_score = min(bandwidth_all_hops) / max(latency_sum)"
        },
        {
          "name": "cost",
          "description": "Minimize total cost per GB/hour",
          "weight": "user_configurable",
          "calculation": "cost_score = 1 / sum(hop_costs)"
        }
      ],
      "scoring_function": "total_score = (brevity_score * W_b) + (security_score * W_s) + (speed_score * W_sp) + (cost_score * W_c)",
      "user_profiles": {
        "balanced": {
          "brevity_weight": 0.25,
          "security_weight": 0.25,
          "speed_weight": 0.25,
          "cost_weight": 0.25
        },
        "speed_priority": {
          "brevity_weight": 0.3,
          "security_weight": 0.1,
          "speed_weight": 0.5,
          "cost_weight": 0.1
        },
        "security_priority": {
          "brevity_weight": 0.1,
          "security_weight": 0.6,
          "speed_weight": 0.2,
          "cost_weight": 0.1
        },
        "cost_priority": {
          "brevity_weight": 0.2,
          "security_weight": 0.2,
          "speed_weight": 0.1,
          "cost_weight": 0.5
        },
        "premium": {
          "brevity_weight": 0.2,
          "security_weight": 0.3,
          "speed_weight": 0.5,
          "cost_weight": 0.0,
          "note": "Premium mode: willing to pay more for speed"
        }
      }
    },
    "multi_hop_routing": {
      "description": "Route packets through multiple VPN nodes",
      "flow": [
        "1. Client requests multi-hop route with preferences",
        "2. Client queries GDB for VPN node statistics",
        "3. Route selection algorithm calculates optimal route",
        "4. Client establishes connection to first hop (entry node)",
        "5. Entry node forwards encrypted traffic to next hop",
        "6. Middle hops relay traffic (double/triple encryption)",
        "7. Exit node decrypts and forwards to destination",
        "8. Response flows back through same route"
      ],
      "encryption_layers": {
        "onion_routing": "Each hop adds/removes one encryption layer",
        "protocol": "Use dap_stream encryption with nested sessions",
        "key_exchange": "Separate session keys for each hop"
      },
      "hop_limit": {
        "min_hops": 1,
        "max_hops": 5,
        "recommended": "2-3 hops for balance of security and performance"
      }
    }
  },
  
