      "Все тесты проходят",
      "Документация обновлена"
    ]
  },
  
  "validation_checklist": {
    "before_commit": [
      "☐ JSON файл валиден (python3 -m json.tool task.json)",
      "☐ auto_load находится в context.context_loading_policy",
      "☐ auto_load содержит ТОЛЬКО .json файлы",
      "☐ Пути в auto_load БЕЗ .context/ префикса",
      "☐ Все файлы из auto_load существуют",
      "☐ Каждая фаза имеет deliverables",
      "☐ Success criteria определены",
      "☐ ./slc update-context выполнен после создания задачи"
    ]
  },
  
  "cli_integration": {
    "description": "Интеграция с SLC CLI",
    "commands": {
      "create_task": "./slc create --title 'Task Name' --category category",
      "list_tasks": "./slc list",
      "update_context": "./slc update-context",
      "load_context": "./slc load-context 'task_id'"
    },
    "automatic_features": [
      "CLI автоматически заполняет auto_load для известных категорий",
      "При создании задачи добавляются базовые core модули",
      "Категория-специфичные модули добавляются автоматически",
      "Рекурсивная загрузка auto_load файлов происходит автоматически"
    ]
  },
  
  "navigation_system": {
