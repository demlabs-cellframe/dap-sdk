  "slc_plugin_cursor_strategies": {
    "approach_1_standard_vscode": {
      "description": "Использовать только standard VS Code API",
      "pros": [
        "Полная совместимость с VS Code",
        "Stable API",
        "Может публиковаться на VS Code Marketplace"
