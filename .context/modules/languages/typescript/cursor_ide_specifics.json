    },
    "approach_2_cursor_detection": {
      "description": "Детект Cursor и использование расширенных features если доступны",
      "implementation": [
        "function isCursor(): boolean {",
        "  const productName = vscode.env.appName;",
        "  return productName.toLowerCase().includes('cursor');",
        "}",
        "",
        "if (isCursor()) {",
        "  // Try Cursor-specific features with fallback",
        "  try {",
        "    // Cursor-specific code",
        "  } catch (error) {",
        "    // Fallback to standard API",
        "  }",
        "}"
      ],
      "pros": [
        "Best of both worlds",
        "Progressive enhancement"
      ],
      "cons": [
        "More complex code",
        "Need to maintain dual code paths"
      ],
      "recommendation": "Для v2.0+ с experimental features"
    },
    "approach_3_cursorrules_manipulation": {
      "description": "Манипуляция .cursorrules для влияния на AI поведение",
      "implementation": "SLC plugin динамически генерирует .cursorrules на основе контекста",
      "pros": [
        "Works with Cursor AI natively",
        "No need for undocumented APIs",
        "Portable - rules are just text files"
      ],
      "cons": [
        "Limited to what .cursorrules can express",
        "Static rules, not dynamic context injection"
      ],
      "recommendation": "РЕКОМЕНДУЕТСЯ в комбинации с approach_1"
    }
  },
  "recommended_architecture_for_slc": {
    "core_strategy": "Standard VS Code APIs + .cursorrules manipulation",
    "components": {
      "context_monitor": {
        "api": "Standard VS Code workspace и editor APIs",
        "implementation": "Track открытые файлы, редактор changes, token count estimation"
      },
      "module_manager": {
        "api": "Standard file system APIs (vscode.workspace.fs)",
        "implementation": "Dynamic loading Markdown knowledge base"
      },
      "cursorrules_generator": {
        "api": "File system write",
        "implementation": [
          "class CursorRulesGenerator {",
          "  async updateRules(context: SlcContext): Promise<void> {",
          "    const rules = this.generateRules(context);",
          "    const rulesPath = this.getCursorRulesPath();",
          "    await vscode.workspace.fs.writeFile(",
          "      vscode.Uri.file(rulesPath),",
          "      Buffer.from(rules)",
          "    );",
          "  }",
          "",
          "  private generateRules(context: SlcContext): string {",
          "    return `",
          "# SLC Auto-Generated Rules",
          "# Updated: ${new Date().toISOString()}",
          "",
          "## Current Context",
          "- Task: ${context.currentTask}",
          "- Loaded Modules: ${context.modules.join(', ')}",
          "",
          "## Active Thought Injections",
          "${context.thoughts.map(t => `- ${t.content}`).join('\\n')}",
          "",
          "## Critical Reminders",
          "${context.reminders.join('\\n')}",
          "    `;",
          "  }",
          "}"
        ]
      },
      "status_bar": {
        "api": "vscode.window.createStatusBarItem",
        "display": "SLC: 145K/200K [██████████░░] 72%"
      },
      "webview_dashboard": {
        "api": "vscode.window.createWebviewPanel",
        "content": "Performance metrics, context analysis, module status"
      },
      "autonomous_mode": {
        "api": "Standard commands, tasks, terminal",
        "validation": "Run tests via terminal, parse output, check TODO completion"
      }
    }
