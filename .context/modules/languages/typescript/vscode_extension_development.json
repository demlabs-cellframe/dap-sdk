  "debugging": {
    "launch_configuration": {
      "file": ".vscode/launch.json",
      "example": [
        "{",
        "  \"version\": \"0.2.0\",",
        "  \"configurations\": [",
        "    {",
        "      \"name\": \"Run Extension\",",
        "      \"type\": \"extensionHost\",",
        "      \"request\": \"launch\",",
        "      \"args\": [\"--extensionDevelopmentPath=${workspaceFolder}\"],",
        "      \"outFiles\": [\"${workspaceFolder}/dist/**/*.js\"],",
        "      \"preLaunchTask\": \"npm: watch\"",
        "    }",
        "  ]",
        "}"
      ]
    },
    "debugging_tips": [
