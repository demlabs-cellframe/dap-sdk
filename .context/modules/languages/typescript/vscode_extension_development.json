{
  "name": "VS Code Extension Development Guide",
  "version": "1.0.0",
  "category": "language",
  "priority": "high",
  "created": "2025-11-14T18:20:00Z",
  "description": "Полное руководство по разработке расширений для Visual Studio Code",
  "based_on": "VS Code Extension API documentation 2024-2025 and web research",
  "getting_started": {
    "prerequisites": {
      "required": [
        "Node.js 18+ и npm",
        "Visual Studio Code",
        "TypeScript 5+",
        "Git"
      ],
      "recommended": [
        "Yeoman и generator-code для scaffolding",
        "vsce для packaging и publishing"
      ]
    },
    "installation": {
      "yeoman_generator": "npm install -g yo generator-code",
      "vsce_tool": "npm install -g vsce",
      "create_extension": "yo code"
    },
    "project_structure": {
      "essential_files": {
        "package.json": "Extension manifest с metadata и contributions",
        "src/extension.ts": "Точка входа с activate() и deactivate()",
        "tsconfig.json": "TypeScript configuration",
        ".vscodeignore": "Файлы для исключения из VSIX package"
      },
      "typical_structure": [
        "my-extension/",
        "├── src/",
        "│   ├── extension.ts     # Entry point",
        "│   ├── commands/        # Command implementations",
        "│   ├── providers/       # Language providers",
        "│   └── utils/           # Utilities",
        "├── resources/           # Icons, images",
        "├── test/               # Tests",
        "├── package.json",
        "├── tsconfig.json",
        "└── README.md"
      ]
    }
  },
  "core_concepts": {
    "activation_events": {
      "description": "Определяют когда расширение активируется",
      "common_events": {
        "onStartupFinished": "После полной загрузки VS Code (рекомендуется)",
        "onCommand": "При выполнении команды",
        "onLanguage": "При открытии файла определенного языка",
        "onView": "При открытии определенного view",
        "workspaceContains": "Когда workspace содержит определенный файл"
      },
      "example": [
        "\"activationEvents\": [",
        "  \"onStartupFinished\",",
        "  \"onCommand:myext.helloWorld\",",
        "  \"onLanguage:typescript\"",
        "]"
      ],
      "best_practice": "Используйте onStartupFinished вместо * для lazy loading"
    },
    "contribution_points": {
      "description": "Декларативные расширения функциональности VS Code",
      "commands": {
        "definition": "Регистрация команд в Command Palette",
        "example": {
          "contributes": {
            "commands": [
              {
                "command": "myext.helloWorld",
                "title": "Hello World",
                "category": "My Extension"
              }
            ]
          }
        }
      },
      "menus": {
        "locations": [
          "commandPalette - Command Palette",
          "editor/context - Контекстное меню редактора",
          "explorer/context - Контекстное меню Explorer",
          "editor/title - Тулбар редактора",
          "view/title - Тулбар custom view"
        ]
      },
      "keybindings": {
        "description": "Горячие клавиши для команд",
        "example": {
          "contributes": {
            "keybindings": [
              {
                "command": "myext.helloWorld",
                "key": "ctrl+shift+h",
                "mac": "cmd+shift+h",
                "when": "editorTextFocus"
              }
            ]
          }
        }
      },
      "configuration": {
        "description": "Настройки расширения в Settings",
        "example": {
          "contributes": {
            "configuration": {
              "title": "My Extension",
              "properties": {
                "myext.enabled": {
                  "type": "boolean",
                  "default": true,
                  "description": "Enable My Extension"
                }
              }
            }
          }
        }
      },
      "views": {
        "description": "Custom views в Activity Bar или Panel",
        "containers": ["activitybar", "panel"],
        "example": {
          "contributes": {
            "viewsContainers": {
              "activitybar": [
                {
                  "id": "myext-explorer",
                  "title": "My Extension",
                  "icon": "resources/icon.svg"
                }
              ]
            },
            "views": {
              "myext-explorer": [
                {
                  "id": "myext.treeView",
                  "name": "Tree View"
                }
              ]
            }
          }
        }
      }
    },
    "extension_api": {
      "vscode_module": {
        "description": "Главный API модуль",
        "import": "import * as vscode from 'vscode';",
        "namespaces": {
          "commands": "Регистрация и выполнение команд",
          "window": "Взаимодействие с UI (messages, input, output)",
          "workspace": "Работа с workspace (files, configuration)",
          "languages": "Language features (diagnostics, completion)",
          "extensions": "Информация о расширениях",
          "env": "Информация об окружении"
        }
      }
    }
  },
  "common_patterns": {
    "command_registration": {
      "description": "Регистрация команд в activate()",
      "pattern": [
        "export function activate(context: vscode.ExtensionContext): void {",
        "  const disposable = vscode.commands.registerCommand(",
        "    'myext.helloWorld',",
        "    async () => {",
        "      await vscode.window.showInformationMessage('Hello World!');",
        "    }",
        "  );",
        "  context.subscriptions.push(disposable);",
        "}"
      ],
      "important": "ВСЕГДА добавляйте disposable в context.subscriptions для cleanup"
    },
    "configuration_reading": {
      "pattern": [
        "const config = vscode.workspace.getConfiguration('myext');",
        "const enabled = config.get<boolean>('enabled', true);",
        "const timeout = config.get<number>('timeout', 5000);"
      ],
      "watching_changes": [
        "vscode.workspace.onDidChangeConfiguration((e) => {",
        "  if (e.affectsConfiguration('myext')) {",
        "    // Reload configuration",
        "  }",
        "});"
      ]
    },
    "file_system_operations": {
      "read_file": [
        "const uri = vscode.Uri.file('/path/to/file');",
        "const content = await vscode.workspace.fs.readFile(uri);",
        "const text = Buffer.from(content).toString('utf8');"
      ],
      "write_file": [
        "const uri = vscode.Uri.file('/path/to/file');",
        "const content = Buffer.from('Hello World', 'utf8');",
        "await vscode.workspace.fs.writeFile(uri, content);"
      ],
      "file_watcher": [
        "const watcher = vscode.workspace.createFileSystemWatcher('**/*.ts');",
        "watcher.onDidChange((uri) => console.log('Changed:', uri));",
        "watcher.onDidCreate((uri) => console.log('Created:', uri));",
        "watcher.onDidDelete((uri) => console.log('Deleted:', uri));",
        "context.subscriptions.push(watcher);"
      ]
    },
    "ui_interactions": {
      "messages": {
        "information": "vscode.window.showInformationMessage('Info')",
        "warning": "vscode.window.showWarningMessage('Warning')",
        "error": "vscode.window.showErrorMessage('Error')",
        "with_actions": [
          "const result = await vscode.window.showInformationMessage(",
          "  'Choose action',",
          "  'Option 1',",
          "  'Option 2'",
          ");",
          "if (result === 'Option 1') { ... }"
        ]
      },
      "input_box": [
        "const input = await vscode.window.showInputBox({",
        "  prompt: 'Enter value',",
        "  placeHolder: 'e.g., example',",
        "  validateInput: (value) => {",
        "    return value.length > 0 ? null : 'Value required';",
        "  }",
        "});"
      ],
      "quick_pick": [
        "const items = ['Option 1', 'Option 2', 'Option 3'];",
        "const selected = await vscode.window.showQuickPick(items, {",
        "  placeHolder: 'Select an option'",
        "});"
      ]
    },
    "webview_panel": {
      "description": "Custom UI с HTML/CSS/JS",
      "creation": [
        "const panel = vscode.window.createWebviewPanel(",
        "  'myWebview',",
        "  'My Webview',",
        "  vscode.ViewColumn.One,",
        "  {",
        "    enableScripts: true,",
        "    retainContextWhenHidden: true",
        "  }",
        ");",
        "",
        "panel.webview.html = getWebviewContent();",
        "",
        "// Message passing",
        "panel.webview.onDidReceiveMessage(",
        "  async (message) => {",
        "    if (message.command === 'doSomething') {",
        "      // Handle message",
        "    }",
        "  }",
        ");"
      ],
      "security": [
        "Use Content Security Policy",
        "Sanitize HTML content",
        "Use nonces for inline scripts"
      ]
    },
    "tree_view": {
      "description": "Hierarchical view в sidebar",
      "implementation": [
        "class MyTreeDataProvider implements vscode.TreeDataProvider<MyTreeItem> {",
        "  private _onDidChangeTreeData = new vscode.EventEmitter<MyTreeItem | undefined>();",
        "  readonly onDidChangeTreeData = this._onDidChangeTreeData.event;",
        "",
        "  refresh(): void {",
        "    this._onDidChangeTreeData.fire(undefined);",
        "  }",
        "",
        "  getTreeItem(element: MyTreeItem): vscode.TreeItem {",
        "    return element;",
        "  }",
        "",
        "  getChildren(element?: MyTreeItem): Thenable<MyTreeItem[]> {",
        "    // Return children",
        "    return Promise.resolve([]);",
        "  }",
        "}",
        "",
        "// Register",
        "const treeDataProvider = new MyTreeDataProvider();",
        "vscode.window.registerTreeDataProvider('myext.treeView', treeDataProvider);"
      ]
    },
    "status_bar": {
      "creation": [
        "const statusBar = vscode.window.createStatusBarItem(",
        "  vscode.StatusBarAlignment.Left,",
        "  100",
        ");",
        "statusBar.text = '$(check) Ready';",
        "statusBar.tooltip = 'Extension Status';",
        "statusBar.command = 'myext.showStatus';",
        "statusBar.show();",
        "context.subscriptions.push(statusBar);"
      ],
      "icons": "Use codicons: $(icon-name)"
    }
  },
  "advanced_features": {
    "language_features": {
      "completion_provider": {
        "description": "IntelliSense автодополнение",
        "registration": [
          "vscode.languages.registerCompletionItemProvider(",
          "  'typescript',",
          "  {",
          "    provideCompletionItems(document, position) {",
          "      const items: vscode.CompletionItem[] = [];",
          "      const item = new vscode.CompletionItem('myFunction');",
          "      item.kind = vscode.CompletionItemKind.Function;",
          "      item.insertText = new vscode.SnippetString('myFunction($1)');",
          "      items.push(item);",
          "      return items;",
          "    }",
          "  },",
          "  '.' // Trigger character",
          ");"
        ]
      },
      "hover_provider": {
        "description": "Hover информация",
        "registration": [
          "vscode.languages.registerHoverProvider('typescript', {",
          "  provideHover(document, position) {",
          "    return new vscode.Hover('Hover information');",
          "  }",
          "});"
        ]
      },
      "diagnostics": {
        "description": "Errors, warnings, info в Problems panel",
        "usage": [
          "const diagnosticCollection = vscode.languages.createDiagnosticCollection('myext');",
          "context.subscriptions.push(diagnosticCollection);",
          "",
          "const diagnostic = new vscode.Diagnostic(",
          "  new vscode.Range(0, 0, 0, 5),",
          "  'Error message',",
          "  vscode.DiagnosticSeverity.Error",
          ");",
          "diagnosticCollection.set(document.uri, [diagnostic]);"
        ]
      }
    },
    "extension_context": {
      "description": "Хранение состояния расширения",
      "global_state": {
        "usage": [
          "await context.globalState.update('key', value);",
          "const value = context.globalState.get('key');"
        ],
        "scope": "Persists across workspace changes"
      },
      "workspace_state": {
        "usage": [
          "await context.workspaceState.update('key', value);",
          "const value = context.workspaceState.get('key');"
        ],
        "scope": "Specific to current workspace"
      },
      "secrets": {
        "usage": [
          "await context.secrets.store('token', 'secret-value');",
          "const token = await context.secrets.get('token');"
        ],
        "security": "Encrypted storage for sensitive data"
      },
      "extension_path": "context.extensionPath - path to extension directory",
      "storage_path": "context.storagePath - persistent storage location"
    },
    "output_channel": {
      "description": "Логирование в Output panel",
      "usage": [
        "const outputChannel = vscode.window.createOutputChannel('My Extension');",
        "context.subscriptions.push(outputChannel);",
        "outputChannel.appendLine('Log message');",
        "outputChannel.show();"
      ]
    },
    "terminal_integration": {
      "create_terminal": [
        "const terminal = vscode.window.createTerminal('My Terminal');",
        "terminal.show();",
        "terminal.sendText('npm install');"
      ],
      "terminal_task": [
        "const task = new vscode.Task(",
        "  { type: 'shell' },",
        "  vscode.TaskScope.Workspace,",
        "  'Build',",
        "  'myext',",
        "  new vscode.ShellExecution('npm run build')",
        ");",
        "vscode.tasks.executeTask(task);"
      ]
    }
  },
